<view xmlns="http://jmix.io/schema/flowui/view">
    <layout classNames="horizontal-layout card-theme-variant" justifyContent="CENTER">
        <card id="card" width="30em"/>
        <vbox width="min-content" padding="false">
            <vbox id="slotsGroupContainer" padding="false" spacing="false" classNames="options">
                <span text="msg://slotsGroup.label" classNames="options-label"/>

                <flexLayout alignItems="BASELINE">
                    <checkbox id="mediaCheckbox" label="Media:" value="true"/>
                    <select id="mediaSelect"/>
                </flexLayout>
                <checkbox id="headerPrefixCheckbox" label="Header Prefix"/>
                <checkbox id="headerCheckbox" label="Header"/>
                <checkbox id="headerSuffixCheckbox" label="Header Suffix" value="true"/>
                <checkbox id="titleCheckbox" label="Title" value="true"/>
                <checkbox id="subtitleCheckbox" label="Subtitle" value="true"/>
                <flexLayout alignItems="BASELINE">
                    <checkbox id="contentCheckbox" label="Content:" value="true"/>
                    <select id="contentSelect"/>
                </flexLayout>
                <checkbox id="footerCheckbox" label="Footer" value="true"/>
            </vbox>
            <checkboxGroup id="themeGroup" label="msg://themeGroup.label"
                           classNames="options"
                           themeNames="vertical"/>
        </vbox>
    </layout>
</view>
